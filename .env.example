# Smart Pocket Backend Configuration

# Cloudflare Tunnel Token
# Get from: https://one.dash.cloudflare.com/ → Networks → Tunnels
# This enables public HTTPS access without port forwarding
# Leave empty to use regular port 3000 instead
CLOUDFLARED_TOKEN=your-cloudflared-token-here

# API Keys for Bearer Token Authentication
# Supported formats:
#   - Comma-separated: API_KEYS=key1,key2,key3
#   - JSON array: API_KEYS=["key1","key2","key3"]
# Clients exchange API keys for JWT tokens via POST /auth/setup
API_KEYS=dev-api-key-123,test-api-key-456

# JWT Configuration
# Change these in production! Use strong random values.
JWT_ACCESS_SECRET=dev-access-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# Actual Budget Configuration
# Server URL of your Actual Budget instance
# Example: https://actual-budget.example.com
ACTUAL_BUDGET_SERVER_URL=https://your-actual-budget-server.com

# Optional encryption password for Actual Budget
# Leave empty if your Actual Budget instance doesn't use encryption
ACTUAL_BUDGET_PASSWORD=

# Cloud File ID of the Actual Budget to sync
# Found in Actual Budget cloud file settings
ACTUAL_BUDGET_ID=your-cloud-file-id

# Google Sheets Configuration
# Path to Google service account credentials JSON file
# Get from: https://console.cloud.google.com/ → Service Accounts
# Example: /data/keys/google-sheets-service-account.json
GOOGLE_CREDENTIALS_JSON_PATH=/path/to/google-credentials.json

# Google Sheets ID (the spreadsheet ID from the URL)
# Example: 1234567890abcdefghijklmnopqrstuvwxyz
GOOGLE_SHEET_ID=your-google-sheet-id

# Google Sheets worksheet name (sheet tab name)
# Default: Accounts
GOOGLE_SHEET_NAME=Accounts

# Default currency for amounts
# Default: USD
DEFAULT_CURRENCY=USD
